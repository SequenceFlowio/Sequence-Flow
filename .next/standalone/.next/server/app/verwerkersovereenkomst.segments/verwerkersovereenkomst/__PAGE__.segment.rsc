0:{"buildId":"iiSQ9cY0E5gVImAsSPnyr","rsc":["$","$1","c",{"children":[["$","main",null,{"className":"bg-background-3 dark:bg-background-7","children":["$","section",null,{"className":"pt-32 pb-14 sm:pt-36 md:pt-42 md:pb-16 lg:pb-[88px] xl:pt-[180px] xl:pb-[200px]","children":["$","div",null,{"className":"main-container","children":[["$","$L2",null,{"delay":0.1,"children":["$","div",null,{"className":"space-y-3","children":[["$","h2",null,{"children":"Verwerkersovereenkomst"}],["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"children":"Omdat SequenceFlow in het kader van haar dienstverlening persoonsgegevens verwerkt namens haar klanten, is een Verwerkersovereenkomst (VOK) wettelijk verplicht op grond van artikel 28 van de AVG. Deze pagina beschrijft de standaardvoorwaarden die van toepassing zijn. Een door beide partijen getekend exemplaar wordt opgeleverd bij aanvang van de samenwerking."}],["$","p",null,{"children":"Laatste update: februari 2026"}]]}]]}]}],["$","article",null,{"className":"terms-conditions-body","children":[["$","$L2",null,{"delay":0.2,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"1. Partijen en onderwerp"}],["$","p",null,{"children":"De verwerkersovereenkomst wordt gesloten tussen de klant (verwerkingsverantwoordelijke) en SequenceFlow B.V. (verwerker). SequenceFlow verwerkt persoonsgegevens uitsluitend in opdracht van de klant, voor de doeleinden die zijn vastgelegd in de Algemene Voorwaarden en de specifieke dienstbeschrijving."}]]}]}],["$","$L2",null,{"delay":0.3,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"2. Aard en doel van de verwerking"}],["$","p",null,{"children":"SequenceFlow verwerkt persoonsgegevens die noodzakelijk zijn voor de uitvoering van de overeengekomen flows. Denk aan het doorzetten van leadgegevens naar een CRM-systeem, het verwerken van klantenserviceberichten of het synchroniseren van contactgegevens tussen systemen."}],["$","p",null,{"children":"SequenceFlow verwerkt de gegevens uitsluitend voor de vastgelegde doeleinden en niet voor eigen commerciële doeleinden. Er wordt geen gebruik gemaakt van de klantdata voor de training van AI-modellen."}]]}]}],["$","$L2",null,{"delay":0.3,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"3. Beveiligingsmaatregelen"}],["$","p",null,{"children":"SequenceFlow treft passende technische en organisatorische maatregelen om persoonsgegevens te beschermen:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Versleutelde verbindingen (TLS/HTTPS) voor alle datatransport."}],["$","li",null,{"children":"Toegangscontrole op basis van het need-to-know principe."}],["$","li",null,{"children":"Opslag van data uitsluitend op servers binnen de Europese Economische Ruimte."}],["$","li",null,{"children":"Gebruik van geharde en gehostde automatiseringsomgevingen met beveiligde configuraties."}],["$","li",null,{"children":"Periodieke beoordeling van de beveiligingsmaatregelen."}]]}]]}]}],["$","$L2",null,{"delay":0.4,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"4. Subverwerkers"}],["$","p",null,{"children":"SequenceFlow maakt gebruik van subverwerkers voor de infrastructuur en automatiseringstools die nodig zijn voor de flows. SequenceFlow informeert de klant over (wijzigingen in) de inzet van subverwerkers. De klant heeft het recht bezwaar te maken tegen de inzet van een nieuwe subverwerker."}],["$","p",null,{"children":"Alle subverwerkers zijn gevestigd binnen de EER of bieden passende waarborgen voor doorgifte buiten de EER (zoals Standard Contractual Clauses)."}]]}]}],["$","$L2",null,{"delay":0.4,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"5. Datalekprocedure"}],["$","p",null,{"children":["In geval van een beveiligingsincident dat leidt tot (mogelijke) inbreuk op persoonsgegevens, informeert SequenceFlow de klant zo spoedig mogelijk — en in ieder geval binnen"," ","$L3"," na ontdekking — per e-mail. SequenceFlow verleent alle medewerking die nodig is voor eventuele melding aan de Autoriteit Persoonsgegevens."]}]]}]}],"$L4","$L5","$L6","$L7"]}]]}]}]}],null,"$L8"]}],"loading":null,"isPartial":false}
3:["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"72 uur"}]
4:["$","$L2",null,{"delay":0.5,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"6. Rechten van betrokkenen"}],["$","p",null,{"children":"Indien een betrokkene (bijv. een eindklant van de opdrachtgever) een verzoek indient op grond van de AVG (inzage, correctie, verwijdering), verleent SequenceFlow de klant de benodigde technische medewerking om aan dit verzoek te voldoen. SequenceFlow handelt verzoeken van betrokkenen niet zelfstandig af zonder instructie van de klant, tenzij wettelijk verplicht."}]]}]}]
5:["$","$L2",null,{"delay":0.5,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"7. Audit en verantwoording"}],["$","p",null,{"children":"De klant heeft het recht de naleving van deze verwerkersovereenkomst te controleren, met inachtneming van een redelijke opzegtermijn. SequenceFlow verleent alle medewerking en verstrekt de benodigde informatie. Audits worden uitgevoerd op kosten van de klant en mogen de bedrijfsvoering van SequenceFlow niet onevenredig verstoren."}]]}]}]
6:["$","$L2",null,{"delay":0.6,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"8. Beëindiging"}],["$","p",null,{"children":"Bij beëindiging van de hoofdovereenkomst worden alle persoonsgegevens van de klant door SequenceFlow verwijderd of teruggegeven, tenzij wettelijke bewaarplicht van toepassing is. Dit wordt schriftelijk bevestigd."}]]}]}]
