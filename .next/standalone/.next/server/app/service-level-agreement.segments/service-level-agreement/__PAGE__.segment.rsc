"$","ul",null,{"children":[["$","li",null,{"children":"Uitval of foutmeldingen in een flow."}],["$","li",null,{"children":"Afwijkingen in het verwachte volume of de uitvoeringssnelheid."}],["$","li",null,{"children":"Mislukte integraties met externe systemen."}]]}],["$","p",null,{"children":"Monitoring vindt plaats 24/7. Klanten hoeven storingen niet zelf te melden — wij detecteren problemen proactief."}]]}]}],["$","$L2",null,{"delay":0.3,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"3. Responsetijden bij storingen"}],["$","p",null,{"children":"Na detectie van een storing hanteren wij de volgende responsetijden (op werkdagen, tenzij anders overeengekomen):"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"Kritische storing"}]," (flow volledig niet-functioneel, directe omzetimpact):"," ",["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"binnen 4 uur"}]," eerste respons, herstel binnen 24 uur."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"Grote verstoring"}]," (flow gedeeltelijk niet-functioneel): eerste respons"," ",["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"binnen 1 werkdag"}],", herstel binnen 3 werkdagen."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"Kleine verstoring"}]," (flow functioneert, maar met afwijkingen): opgelost in de eerstvolgende onderhoudscyclus."]}]]}]]}]}],["$","$L2",null,{"delay":0.4,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"4. Gepland onderhoud"}],["$","p",null,{"children":["SequenceFlow plant onderhoud bij voorkeur buiten kantooruren (maandag t/m vrijdag, 08:00–18:00 CET). Geplande onderhoudsmomenten worden minimaal"," ",["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"48 uur van tevoren"}]," per e-mail aangekondigd. Spoedeisend onderhoud wegens beveiligingslekken kan zonder voorafgaande aankondiging worden uitgevoerd."]}]]}]}],"$L3","$L4","$L5","$L6"]}]]}]}]}],null,"$L7"]}],"loading":null,"isPartial":false}
