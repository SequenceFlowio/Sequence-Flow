{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/prijzen/layout,_N_T_/prijzen/page,_N_T_/prijzen"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
