text-accent font-medium","children":"Contactgegevens:"}]," naam, e-mailadres, telefoonnummer, bedrijfsnaam en website-URL — verzameld via het Flow Scan formulier of direct contact."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"Gebruiksgegevens:"}]," IP-adres, browsertype, paginabezoeken en interacties op onze website via analysediensten."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-secondary dark:text-accent font-medium","children":"Klantdata:"}]," bedrijfsinformatie die nodig is om flows te bouwen en te beheren. Dit betreft geen persoonsgegevens van de eindklanten van onze opdrachtgevers, tenzij vastgelegd in een verwerkersovereenkomst."]}]]}]]}]}],["$","$L2",null,{"delay":0.3,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"3. Waarom verwerken wij uw gegevens?"}],["$","p",null,{"children":"Wij verwerken persoonsgegevens voor de volgende doeleinden:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Het uitvoeren van de overeenkomst en het leveren van onze diensten."}],["$","li",null,{"children":"Het beantwoorden van vragen en het opvolgen van ingevulde Flow Scan formulieren."}],["$","li",null,{"children":"Het versturen van offertes en facturen."}],["$","li",null,{"children":"Het verbeteren van onze website en diensten op basis van gebruiksanalyses."}],["$","li",null,{"children":"Het nakomen van wettelijke verplichtingen."}]]}],["$","p",null,{"children":"De rechtsgrondslag voor verwerking is in de meeste gevallen de uitvoering van een overeenkomst (art. 6 lid 1 sub b AVG) of ons gerechtvaardigd belang (art. 6 lid 1 sub f AVG)."}]]}]}],["$","$L2",null,{"delay":0.4,"children":["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"children":"4. Hoe lang bewaren wij uw gegevens?"}],["$","p",null,{"children":"Wij bewaren persoonsgegevens niet langer dan noodzakelijk voor het doel waarvoor zij zijn verzameld. Klantgegevens worden bewaard gedurende de looptijd van de overeenkomst en tot 2 jaar daarna voor eventuele nakomende vragen. Financiële gegevens worden conform de wettelijke bewaarplicht 7 jaar bewaard."}]]}]}],"$L3","$L4","$L5","$L6"]}]]}]}]}],null,"$L7"]}],"loading":null,"isPartial":false}
