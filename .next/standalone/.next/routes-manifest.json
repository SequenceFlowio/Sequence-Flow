{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/oplossingen/[slug]",
      "regex": "^/oplossingen/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/oplossingen/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/acceptable-use-policy",
      "regex": "^/acceptable\\-use\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/acceptable\\-use\\-policy(?:/)?$"
    },
    {
      "page": "/ai-data-ethiek",
      "regex": "^/ai\\-data\\-ethiek(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ai\\-data\\-ethiek(?:/)?$"
    },
    {
      "page": "/algemene-voorwaarden",
      "regex": "^/algemene\\-voorwaarden(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/algemene\\-voorwaarden(?:/)?$"
    },
    {
      "page": "/api/chat",
      "regex": "^/api/chat(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/chat(?:/)?$"
    },
    {
      "page": "/api/escalate",
      "regex": "^/api/escalate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/escalate(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/hoe-wij-werken",
      "regex": "^/hoe\\-wij\\-werken(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/hoe\\-wij\\-werken(?:/)?$"
    },
    {
      "page": "/icon.png",
      "regex": "^/icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.png(?:/)?$"
    },
    {
      "page": "/oplossingen",
      "regex": "^/oplossingen(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/oplossingen(?:/)?$"
    },
    {
      "page": "/prijzen",
